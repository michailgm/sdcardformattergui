<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SDCardFormatterApp.MainWindow"
        Title="SD Card Formatter" Width="350" Height="530"
        Background="#F0F0F0" CanResize="False" WindowStartupLocation="CenterScreen"
        Icon="avares://SDCardFormatterApp/Assets/sd_card_icon_48.ico">
    <Window.Styles>
        <Style Selector="Button:focus">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="HeaderedContentControl.GroupBox">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid RowDefinitions="Auto,*" Margin="0,5,0,5">
                        <Border Grid.Row="0" Grid.RowSpan="2"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,10,0,0" />

                        <ContentPresenter Name="PART_HeaderPresenter"
                                          Grid.Row="0"
                                          Content="{TemplateBinding Header}"
                                          Margin="12,0,0,0"
                                          Padding="5,0"
                                          Background="#F0F0F0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          FontWeight="SemiBold"
                                          ZIndex="1">
                            <ContentPresenter.DataTemplates>
                                <DataTemplate DataType="x:String">
                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="12" Foreground="#333333" />
                                </DataTemplate>
                            </ContentPresenter.DataTemplates>
                        </ContentPresenter>

                        <ContentPresenter Name="PART_ContentPresenter"
                                          Grid.Row="1"
                                          Content="{TemplateBinding Content}"
                                          Padding="15,10,15,15" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
    </Window.Styles>
    <Grid RowDefinitions="*, Auto">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8" Spacing="10">
                <Label Content="Избери SD карта" FontWeight="SemiBold" Foreground="#333333" FontSize="13" />
                <ComboBox Name="DriveSelector" HorizontalAlignment="Stretch" SelectedIndex="0" FontSize="13"
                          SelectionChanged="OnSelectionChanged">
                    <ComboBox.Items>
                        <ComboBoxItem IsEnabled="False"
                                      Foreground="Gray"
                                      FontStyle="Italic"
                                      Tag="Placeholder">
                            <TextBlock Text="💾 Поставете SD карта"
                                       FontSize="8"
                                       Opacity="0.7"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </ComboBoxItem>
                    </ComboBox.Items>
                    <ComboBoxItem></ComboBoxItem>
                </ComboBox>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="12" Background="White" CornerRadius="2">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Spacing="6">
                            <Label Content="Информация за картата" FontWeight="SemiBold" Margin="0,0,0,5" />
                            <TextBlock Name="CardTypeTxt" Text="Тип: --" FontSize="12" Foreground="#555555" />
                            <TextBlock Name="CapacityTxt" Text="Капацитет: --" FontSize="12" Foreground="#555555" />
                        </StackPanel>
                        <Image Name="CardTypeLogo" Grid.Column="1" Width="60" Height="40" VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                    </Grid>
                </Border>

                <HeaderedContentControl Classes="GroupBox" Header="Опции за форматиране">
                    <StackPanel Spacing="3">
                        <RadioButton Name="QuickFormatRb" Content="Бърз формат" FontSize="13" IsChecked="True" />
                        <RadioButton Name="OverwriteFormatRb" Content="Пълен формат" FontSize="13" />
                        <Label Content="Етикет на дяла" FontWeight="SemiBold" Margin="0,5,0,0" FontSize="13" />
                        <TextBox Name="VolumeLabelTxt" Watermark="SDCARD" FontSize="13" MaxLength="11" />                        
                    </StackPanel>
                </HeaderedContentControl>
                
                <StackPanel Spacing="5" Margin="0,0,0,0">
                    <ProgressBar Name="FormatProgress" Height="15" Minimum="0" Maximum="100" Value="0" FontSize="13"
                                 ShowProgressText="True" Foreground="#0078D7" />
                    <TextBlock Name="StatusTxt" Text="В готовност" FontSize="11" HorizontalAlignment="Center"
                               Foreground="#666666" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,0,0,0">
                    <Button Name="FormatBtn" Content="Форматиране" Width="120" Height="30" FontSize="13"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="#0078D7" Foreground="White" Click="OnFormatClicked" />

                    <Button Name="ExitBtn" Content="Изход" Width="90" Height="30" FontSize="13"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Click="OnExitClicked" />
                </StackPanel>
                
                <Label Content="SD Logo, SDHC Logo and SDXC Logo are trademarks of SD-3C, LLC." FontSize="10" Margin="0,5,0,0" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="1" Background="#E0E0E0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Статус индикатор (зелено/червено кръгче) -->
                <Ellipse Grid.Column="0" Name="StatusIndicator" Width="10" Height="10" Fill="Green" Margin="0,0,8,0"
                         VerticalAlignment="Center" />

                <!-- Информация за SD карта -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                    <TextBlock Text="💾" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Name="CardStatusText" Text="Няма карта" Foreground="#666666" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>