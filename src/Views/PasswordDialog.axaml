<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="400" d:DesignHeight="200"
        Width="350" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        x:Class="SDCardFormatterApp.PasswordDialog"
        Title="Въведете sudo парола"
        FontFamily="Segoe UI, sans-serif">
    <Window.Styles>
        <Style Selector="Button:focus">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </Window.Styles>
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto" VerticalAlignment="Center">
        <TextBlock Text="Моля, въведете вашата sudo парола:"
                   Margin="0,0,0,15"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />

        <!-- Използваме TextBox с PasswordChar -->
        <TextBox Name="PasswordField"
                 Grid.Row="1"
                 Watermark="Парола"
                 Margin="0,0,0,20"
                 PasswordChar="●" />

        <StackPanel Name="ButtonPanel"
                    Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10">
            <Button Name="OkButton"
                    Width="80"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Background="#0078D7"
                    Foreground="White"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <Image Source="avares://SDCardFormatterApp/Assets/ok_32pt.png"
                           Width="16" Height="16"
                           VerticalAlignment="Center" />
                    <TextBlock Text="OK" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Name="CancelButton"
                    Width="80"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <Image Source="avares://SDCardFormatterApp/Assets/cancel_32pt.png"
                           Width="16" Height="16"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Отказ" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>